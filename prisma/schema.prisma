generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  EDITOR
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  LOCKED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskState {
  DRAFT
  PENDING_ASSIGNMENT
  OFFERED
  ACCEPTED
  IN_EDITING
  UPLOADED
  IN_REVIEW
  NEEDS_CORRECTION
  APPROVED
  DELIVERED
  CLOSED
  CANCELLED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum AssignmentMode {
  AUTOMATIC
  MANUAL
}

enum TaskAssignmentFlowStatus {
  PENDING_OFFER
  ACCEPTED
  REJECTED
  DIVIDED
}

enum SystemAssignmentMode {
  AUTOMATIC
  MANUAL
}

enum SubmissionStatus {
  SUBMITTED
  SUPERSEDED
}

enum ReviewDecision {
  APPROVED
  NEEDS_CORRECTION
}

enum PaymentStatus {
  CALCULATED
  PENDING_OWNER_APPROVAL
  APPROVED
  PAID
  CANCELLED
}

enum CampaignPlanPreset {
  PLAN_12
  PLAN_20
  PLAN_30
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  CANCELLED
}

enum CampaignBillingStatus {
  PENDING_COLLECTION
  COLLECTED
  CANCELLED
}

enum FinancialMovementType {
  INCOME
  EXPENSE
}

enum FinancialMovementStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  NEW_TASK
  TASK_ACCEPTED
  TASK_OVERDUE
  REVIEW_REQUIRED
  PAYMENT_SETTLED
  REMINDER
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
}

enum LearningLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearningProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                  String   @id @default(cuid())
  publicUuid          String   @unique @default(uuid())
  email               String   @unique
  passwordHash        String
  phoneEncrypted      String?
  phoneKeyVersion     Int?
  fullName            String?
  displayName         String
  avatarUrl           String?
  role                Role
  status              UserStatus @default(ACTIVE)
  country             String?
  timezone            String   @default("UTC")
  declaredLevel       LearningLevel?
  softwareStack       Json?
  availabilityText    String?
  failedLoginAttempts Int      @default(0)
  lockUntil           DateTime?
  lastLoginAt         DateTime?
  workloadScore       Int      @default(0)
  acceptedOffersCount Int      @default(0)
  totalOffersCount    Int      @default(0)
  acceptanceRate      Float    @default(0)
  sessionVersion      Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  accounts            Account[]
  sessions            Session[]
  createdClients      Client[]           @relation("ClientCreatedBy")
  createdProjects     Project[]          @relation("ProjectCreatedBy")
  createdCampaigns    Campaign[]         @relation("CampaignCreatedBy")
  defaultCampaigns    Campaign[]         @relation("CampaignDefaultEditor")
  createdTasks        Task[]             @relation("TaskCreatedBy")
  taskAssignments     TaskAssignment[]   @relation("AssignmentEditor")
  submissions         Submission[]       @relation("SubmissionAuthor")
  reviews             Review[]           @relation("ReviewReviewer")
  editorEarnings      EditorEarning[]    @relation("EditorEarnings")
  approvedEarnings    EditorEarning[]    @relation("ApprovedEarnings")
  notifications       Notification[]
  auditLogs           AuditLog[]         @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  twoFactorChallenges TwoFactorChallenge[]
  taskFiles           TaskFile[]         @relation("FileUploader")
  taskStatusChanges   TaskStatusHistory[] @relation("TaskStatusChangedBy")
  integrationSecrets  IntegrationSecret[] @relation("IntegrationSecretCreatedBy")
  learningProgress    LearningProgress[]
  directlyAssignedTasks Task[]            @relation("TaskDirectEditor")
  createdFinancialMovements FinancialMovement[] @relation("FinancialMovementCreatedBy")
  linkedFinancialMovements FinancialMovement[] @relation("FinancialMovementEditor")
  workerNotesAuthored WorkerNote[]        @relation("WorkerNoteAuthor")
  workerNotesReceived WorkerNote[]        @relation("WorkerNoteWorker")
  taskChangeLogsAuthored TaskChangeLog[]  @relation("TaskChangeLogAuthor")
  taskChangeAcks       TaskChangeAck[]    @relation("TaskChangeAckEditor")
}

model Client {
  id              String      @id @default(cuid())
  name            String
  brandName       String?
  email           String?
  phoneEncrypted  String?
  phoneKeyVersion Int?
  status          ClientStatus @default(ACTIVE)
  notesEncrypted  String?
  notesKeyVersion Int?
  stylePreferences Json?
  references      Json?
  packSize        Int?
  packPrice       Decimal?    @db.Decimal(14, 2)
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  createdBy       User        @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  projects        Project[]
  campaigns       Campaign[]
  tasks           Task[]
  payments        Payment[]
  financialMovements FinancialMovement[]

  @@index([createdById])
}

model Project {
  id                String    @id @default(cuid())
  clientId          String
  title             String
  description       String?
  packSize          Int
  packPrice         Decimal   @db.Decimal(14, 2)
  currency          String    @default("ARS")
  defaultStyleNotes String?
  active            Boolean   @default(true)
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client            Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy         User      @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tasks             Task[]
  payments          Payment[]

  @@index([clientId])
  @@index([createdById])
}

model Campaign {
  id               String                @id @default(cuid())
  clientId         String
  name             String
  planPreset       CampaignPlanPreset
  videosPerCycle   Int
  pricePerVideo    Decimal               @db.Decimal(14, 2)
  currency         String                @default("ARS")
  startDate        DateTime
  leadDays         Int                   @default(1)
  defaultEditorId  String?
  status           CampaignStatus        @default(DRAFT)
  billingStatus    CampaignBillingStatus @default(PENDING_COLLECTION)
  publishedAt      DateTime?
  createdById      String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  client           Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  defaultEditor    User?                 @relation("CampaignDefaultEditor", fields: [defaultEditorId], references: [id], onDelete: SetNull)
  createdBy        User                  @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  tasks            Task[]
  rawFiles         TaskFile[]
  financialMovements FinancialMovement[]

  @@index([clientId])
  @@index([defaultEditorId])
  @@index([status])
  @@index([billingStatus])
  @@index([startDate])
}

model Task {
  id                       String       @id @default(cuid())
  projectId                String?
  campaignId               String?
  clientId                 String?
  directEditorId           String?
  videoIndex               Int?
  title                    String
  description              String?
  instructions             String?
  deadlineAt               DateTime?
  publishAt                DateTime?
  priority                 TaskPriority @default(MEDIUM)
  estimatedDurationMinutes Int?
  state                    TaskState    @default(DRAFT)
  assignedMode             String       @default("manual")
  assignmentMode           AssignmentMode @default(MANUAL)
  assignmentFlowStatus     TaskAssignmentFlowStatus @default(PENDING_OFFER)
  offerExpiresAt           DateTime?
  offeredEditorIds         String[]
  assignmentAttempt        Int          @default(0)
  parentTaskId             String?
  totalVideos              Int?
  splitChunkSize           Int?         @default(10)
  rawAssetsReady           Boolean      @default(false)
  createdById              String
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  project                  Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  campaign                 Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  client                   Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  directEditor             User?        @relation("TaskDirectEditor", fields: [directEditorId], references: [id], onDelete: SetNull)
  createdBy                User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  parentTask               Task?        @relation("TaskParent", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks               Task[]       @relation("TaskParent")
  assignments              TaskAssignment[]
  statusHistory            TaskStatusHistory[]
  files                    TaskFile[]
  financialMovements       FinancialMovement[]
  changeLogs               TaskChangeLog[]

  @@index([projectId])
  @@index([campaignId])
  @@index([clientId])
  @@index([directEditorId])
  @@index([publishAt])
  @@index([campaignId, videoIndex])
  @@index([state])
  @@index([assignmentFlowStatus])
  @@index([offerExpiresAt])
  @@index([parentTaskId])
  @@index([deadlineAt])
}

model TaskAssignment {
  id               String           @id @default(cuid())
  taskId           String
  editorId         String
  status           AssignmentStatus @default(ASSIGNED)
  assignedAt       DateTime         @default(now())
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  completedAt      DateTime?
  percentageOfTask Decimal          @db.Decimal(5, 2) @default(100)
  rejectionReason  String?
  offerExpiresAt   DateTime?
  offerRound       Int              @default(0)
  autoCancelledAt  DateTime?

  task             Task             @relation(fields: [taskId], references: [id], onDelete: Restrict)
  editor           User             @relation("AssignmentEditor", fields: [editorId], references: [id], onDelete: Restrict)
  submissions      Submission[]
  earnings         EditorEarning[]
  files            TaskFile[]

  @@index([taskId])
  @@index([editorId])
}

model TaskStatusHistory {
  id          String    @id @default(cuid())
  taskId      String
  fromState   TaskState?
  toState     TaskState
  changedById String
  comment     String?
  changedAt   DateTime  @default(now())

  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy   User      @relation("TaskStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([taskId, changedAt])
}

model TaskFile {
  id           String         @id @default(cuid())
  taskId       String?
  campaignId   String?
  assignmentId String?
  uploadedById String
  storageKey   String         @unique
  bucket       String
  originalName String
  mimeType     String
  sizeBytes    Int
  version      Int            @default(1)
  isFinal      Boolean        @default(false)
  createdAt    DateTime       @default(now())

  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  campaign     Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  assignment   TaskAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  uploadedBy   User           @relation("FileUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  submissions  Submission[]

  @@index([taskId])
  @@index([campaignId])
  @@index([assignmentId])
}

model Submission {
  id               String           @id @default(cuid())
  taskAssignmentId String
  submittedById    String
  submittedAt      DateTime         @default(now())
  fileId           String?
  notes            String?
  status           SubmissionStatus @default(SUBMITTED)

  taskAssignment   TaskAssignment   @relation(fields: [taskAssignmentId], references: [id], onDelete: Restrict)
  submittedBy      User             @relation("SubmissionAuthor", fields: [submittedById], references: [id], onDelete: Restrict)
  file             TaskFile?        @relation(fields: [fileId], references: [id], onDelete: SetNull)
  reviews          Review[]

  @@index([taskAssignmentId])
}

model Review {
  id           String         @id @default(cuid())
  submissionId String
  reviewedById String
  decision     ReviewDecision
  comments     String?
  reviewedAt   DateTime       @default(now())

  submission   Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewedBy   User           @relation("ReviewReviewer", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@index([submissionId])
}

model Payment {
  id          String        @id @default(cuid())
  projectId   String?
  clientId    String?
  totalAmount Decimal       @db.Decimal(14, 2)
  currency    String        @default("ARS")
  status      PaymentStatus @default(CALCULATED)
  billedAt    DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  earnings    EditorEarning[]

  @@index([projectId])
  @@index([clientId])
}

model EditorEarning {
  id                     String        @id @default(cuid())
  taskAssignmentId       String        @unique
  editorId               String
  paymentId              String?
  baseValue              Decimal       @db.Decimal(14, 2)
  editorPercentage       Decimal       @db.Decimal(5, 2)
  agencyPercentage       Decimal       @db.Decimal(5, 2)
  assignmentPercentage   Decimal       @db.Decimal(5, 2)
  grossAmount            Decimal       @db.Decimal(14, 2)
  agencyCommissionAmount Decimal       @db.Decimal(14, 2)
  editorNetAmount        Decimal       @db.Decimal(14, 2)
  currency               String        @default("ARS")
  status                 PaymentStatus @default(CALCULATED)
  calculatedAt           DateTime      @default(now())
  submittedForApprovalAt DateTime?
  approvedAt             DateTime?
  paidAt                 DateTime?
  approvedById           String?
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  taskAssignment         TaskAssignment @relation(fields: [taskAssignmentId], references: [id], onDelete: Restrict)
  editor                 User           @relation("EditorEarnings", fields: [editorId], references: [id], onDelete: Restrict)
  payment                Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  approvedBy             User?          @relation("ApprovedEarnings", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([editorId])
  @@index([status])
}

model LearningResource {
  id          String      @id @default(cuid())
  title       String
  description String?
  url         String      @unique
  level       LearningLevel
  tags        String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  progress    LearningProgress[]
}

model LearningProgress {
  id          String                  @id @default(cuid())
  userId      String
  resourceId  String
  status      LearningProgressStatus  @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource    LearningResource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Notification {
  id           String             @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  message      String
  status       NotificationStatus @default(UNREAD)
  metadataJson Json?
  createdAt    DateTime           @default(now())
  readAt       DateTime?

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
}

model IntegrationSecret {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  valueEncrypted String
  keyVersion     Int
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy      User     @relation("IntegrationSecretCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorChallenge {
  id            String   @id @default(cuid())
  userId        String
  emailSnapshot String
  codeHash      String
  expiresAt     DateTime
  attempts      Int      @default(0)
  maxAttempts   Int      @default(5)
  resendCount   Int      @default(0)
  verifiedAt    DateTime?
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemConfig {
  id             String               @id @default("default")
  assignmentMode SystemAssignmentMode @default(AUTOMATIC)
  darkModeEnabled Boolean             @default(true)
  editorSignupOpen Boolean            @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model FinancialMovement {
  id          String                  @id @default(cuid())
  type        FinancialMovementType
  status      FinancialMovementStatus @default(CONFIRMED)
  subtype     String?
  amount      Decimal                 @db.Decimal(14, 2)
  currency    String                  @default("ARS")
  occurredAt  DateTime                @default(now())
  description String
  method      String?
  notes       String?
  clientId    String?
  campaignId  String?
  taskId      String?
  editorId    String?
  createdById String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  client      Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  campaign    Campaign?               @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  task        Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  editor      User?                   @relation("FinancialMovementEditor", fields: [editorId], references: [id], onDelete: SetNull)
  createdBy   User                    @relation("FinancialMovementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([occurredAt])
  @@index([type, status])
  @@index([clientId])
  @@index([campaignId])
  @@index([taskId])
  @@index([editorId])
}

model WorkerNote {
  id         String   @id @default(cuid())
  workerId   String
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  worker     User     @relation("WorkerNoteWorker", fields: [workerId], references: [id], onDelete: Cascade)
  author     User     @relation("WorkerNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([workerId, createdAt])
}

model TaskChangeLog {
  id               String   @id @default(cuid())
  taskId            String
  changedById       String
  beforeJson        Json
  afterJson         Json
  changedFields     String[]
  requiresAck       Boolean  @default(false)
  createdAt         DateTime @default(now())

  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy         User     @relation("TaskChangeLogAuthor", fields: [changedById], references: [id], onDelete: Restrict)
  acknowledgements  TaskChangeAck[]

  @@index([taskId, createdAt])
}

model TaskChangeAck {
  id             String   @id @default(cuid())
  changeLogId    String
  editorId       String
  acknowledgedAt DateTime @default(now())

  changeLog      TaskChangeLog @relation(fields: [changeLogId], references: [id], onDelete: Cascade)
  editor         User          @relation("TaskChangeAckEditor", fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([changeLogId, editorId])
  @@index([editorId, acknowledgedAt])
}
